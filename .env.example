# ── App ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://czechdatasync.cz
NEXT_PUBLIC_APP_NAME=CzechDataSync
CRON_SECRET=replace_with_random_secret

# ── Database (Vercel Postgres / Neon) ────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/czechdatasync?sslmode=require
DIRECT_URL=postgresql://user:password@host:5432/czechdatasync?sslmode=require

# ── Auth (Clerk) — https://clerk.com ────────────────────────────────
# Copy from Clerk Dashboard → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=<your_clerk_publishable_key>
CLERK_SECRET_KEY=<your_clerk_secret_key>
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/app
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/app
# Copy from Clerk Dashboard → Webhooks → Signing Secret
CLERK_WEBHOOK_SECRET=<your_clerk_webhook_secret>

# ── Vercel KV (API key encryption) ──────────────────────────────────
# Copy from Vercel Dashboard → Storage → KV
KV_URL=<your_kv_url>
KV_REST_API_URL=<your_kv_rest_api_url>
KV_REST_API_TOKEN=<your_kv_rest_api_token>
KV_REST_API_READ_ONLY_TOKEN=<your_kv_read_only_token>
# Generate: openssl rand -base64 32
ENCRYPTION_KEY=<your_32_char_encryption_key>

# ── Stripe — https://stripe.com ──────────────────────────────────────
# Copy from Stripe Dashboard → Developers → API Keys
STRIPE_SECRET_KEY=<your_stripe_secret_key>
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=<your_stripe_publishable_key>
STRIPE_WEBHOOK_SECRET=<your_stripe_webhook_secret>
STRIPE_PRO_PRICE_ID=<price_id_for_990czk_plan>
STRIPE_BUSINESS_PRICE_ID=<price_id_for_2490czk_plan>

# ── OpenAI — https://platform.openai.com ────────────────────────────
OPENAI_API_KEY=<your_openai_api_key>

# ── RAYNET CRM ───────────────────────────────────────────────────────
# Users provide their own keys — stored encrypted in KV
# RAYNET_API_KEY=
# RAYNET_INSTANCE_NAME=

# ── Shoptet ──────────────────────────────────────────────────────────
# SHOPTET_API_KEY=
# SHOPTET_ESHOP_ID=

# ── Pohoda (Stormware) ───────────────────────────────────────────────
# POHODA_URL=http://localhost:5336
# POHODA_USERNAME=
# POHODA_PASSWORD=
# POHODA_ICO=

# ── Packeta (Zásilkovna) ─────────────────────────────────────────────
# PACKETA_API_KEY=
# PACKETA_API_PASSWORD=

# ── Invoice Email Inbox (SendGrid Inbound Parse) ─────────────────────
# Configure SendGrid webhook URL as:
#   https://webhook:{SENDGRID_INBOUND_SECRET}@yourdomain.com/api/webhooks/inbound-email
# Generate: openssl rand -hex 32
SENDGRID_INBOUND_SECRET=<your_sendgrid_inbound_secret>
# Domain used for inbox addresses (configure MX record pointing to SendGrid)
INVOICE_INBOX_DOMAIN=inbound.czechdatasync.cz
