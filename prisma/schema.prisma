generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                 String   @id @default(cuid())
  clerkId            String   @unique
  email              String   @unique
  name               String?
  company            String?
  ico                String?  // IČO — Czech company registration number
  dic                String?  // DIČ — Czech VAT number
  plan               Plan     @default(FREE)
  inboxToken              String?   @unique // unique token for inbound email address
  autoSendInvoices        Boolean   @default(false)
  invoiceTargetPlatform   Platform? // which platform receives auto-sent invoices
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  connections   Connection[]
  syncs         Sync[]
  subscription  Subscription?
  usageRecords  UsageRecord[]
  invoices      Invoice[]

  @@map("users")
}

model Connection {
  id           String          @id @default(cuid())
  userId       String
  platform     Platform
  name         String
  kvKey        String          @unique // key in Vercel KV where encrypted credentials are stored
  isActive     Boolean         @default(true)
  lastTestedAt DateTime?
  lastTestOk   Boolean?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  user         User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  sourceSyncs  Sync[]          @relation("SourceConnection")
  targetSyncs  Sync[]          @relation("TargetConnection")

  @@unique([userId, platform])
  @@map("connections")
}

model Sync {
  id                String       @id @default(cuid())
  userId            String
  name              String
  sourceConnectionId String
  targetConnectionId String
  templateId        String?      // e.g. "shoptet-raynet-orders"
  fieldMapping      Json         // { sourceField: targetField, ... }
  schedule          Schedule     @default(MANUAL)
  isActive          Boolean      @default(true)
  lastRunAt         DateTime?
  lastRunStatus     RunStatus?
  nextRunAt         DateTime?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  user              User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  sourceConnection  Connection   @relation("SourceConnection", fields: [sourceConnectionId], references: [id])
  targetConnection  Connection   @relation("TargetConnection", fields: [targetConnectionId], references: [id])
  logs              SyncLog[]

  @@map("syncs")
}

model SyncLog {
  id           String    @id @default(cuid())
  syncId       String
  status       RunStatus
  recordsIn    Int       @default(0)
  recordsOut   Int       @default(0)
  errorMessage String?
  durationMs   Int?
  startedAt    DateTime  @default(now())
  finishedAt   DateTime?
  metadata     Json?     // raw API response snippets for debugging

  sync         Sync      @relation(fields: [syncId], references: [id], onDelete: Cascade)

  @@map("sync_logs")
}

model UsageRecord {
  id        String   @id @default(cuid())
  userId    String
  month     String   // "2024-06" format
  syncsRun  Int      @default(0)
  recordsProcessed Int @default(0)

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, month])
  @@map("usage_records")
}

model Subscription {
  id                   String   @id @default(cuid())
  userId               String   @unique
  stripeCustomerId     String   @unique
  stripeSubscriptionId String?  @unique
  stripePriceId        String?
  plan                 Plan     @default(FREE)
  status               SubStatus @default(ACTIVE)
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}

enum Platform {
  RAYNET
  SHOPTET
  POHODA
  PACKETA
  AIRTABLE
  MONEY_S3
  IDOKLAD
  FAKTUROID
  ABRA_FLEXI
}

enum Plan {
  FREE
  PRO
  BUSINESS
}

enum Schedule {
  MANUAL
  EVERY_5MIN
  EVERY_HOUR
  DAILY
  WEEKLY
}

enum RunStatus {
  RUNNING
  SUCCESS
  FAILED
  PARTIAL
}

enum SubStatus {
  ACTIVE
  PAST_DUE
  CANCELLED
  TRIALING
}

model Invoice {
  id               String        @id @default(cuid())
  userId           String

  fromEmail        String
  subject          String?
  receivedAt       DateTime      @default(now())

  variabilniSymbol String?
  ico              String?
  dic              String?
  company          String?
  amount           Float?
  amountWithVat    Float?
  vatRate          Float?
  currency         String?       @default("CZK")
  date             String?       // YYYY-MM-DD
  dateDue          String?       // YYYY-MM-DD
  items            Json?         // ParsedInvoice items array

  fileName         String?

  status           InvoiceStatus @default(PENDING)
  errorMessage     String?
  sentAt           DateTime?

  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  user             User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("invoices")
}

enum InvoiceStatus {
  PENDING
  PARSED
  SENT
  FAILED
}
