PORT=3000
NODE_ENV=production

# Generate with: openssl rand -hex 32
JWT_SECRET=CHANGE_ME_32_chars_minimum

# https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PRICE_ID=price_...
# Webhook: https://dashboard.stripe.com/webhooks → Add endpoint → https://zapi.cz/api/billing/webhook
STRIPE_WEBHOOK_SECRET=whsec_...

APP_URL=https://zapi.cz
ALLOWED_ORIGINS=https://zapi.cz

# Set by docker-compose (mounted volume)
DB_PATH=/data/zapi.db
